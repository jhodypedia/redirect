<%- include('layout', { body: `
<div class="flex h-screen overflow-hidden">
    <aside class="w-64 border-r border-white/10 glass-card flex flex-col z-20 hidden md:flex">
        <div class="h-20 flex items-center px-8 border-b border-white/10">
            <h1 class="text-2xl font-bold text-white tracking-wider flex items-center gap-2">
                PANSA<span class="text-pansa-neon drop-shadow-[0_0_8px_rgba(56,189,248,0.8)]">⚡️</span>
            </h1>
        </div>
        <nav class="flex-1 py-8 px-4 space-y-2">
            <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-pansa-neon/20 text-pansa-neon border border-pansa-neon/30 neon-shadow transition-all">
                <span class="font-medium">Dashboard</span>
            </a>
            <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-rose-400 hover:bg-white/5 transition-all mt-auto absolute bottom-8 w-[calc(16rem-2rem)]">
                <span class="font-medium">Logout</span>
            </a>
        </nav>
    </aside>

    <main class="flex-1 overflow-y-auto p-8 relative z-10">
        <header class="mb-8 flex justify-between items-center">
            <div>
                <h2 class="text-3xl font-bold text-white mb-1">Overview</h2>
                <p class="text-slate-400 text-sm">Real-time link monitoring</p>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="glass-card rounded-2xl p-6 flex items-center gap-4">
                <div class="p-4 bg-emerald-500/20 rounded-xl text-emerald-400 text-2xl font-bold">
                    🚀
                </div>
                <div>
                    <p class="text-sm text-slate-400 font-medium">Active Links</p>
                    <p class="text-3xl font-bold text-white"><%= stats.activeLinks %></p>
                </div>
            </div>
            
            <div class="glass-card rounded-2xl p-6 flex items-center gap-4">
                <div class="p-4 bg-blue-500/20 rounded-xl text-blue-400 text-2xl font-bold">
                    🖱️
                </div>
                <div>
                    <p class="text-sm text-slate-400 font-medium">Total Clicks</p>
                    <p class="text-3xl font-bold text-white"><%= stats.totalClicks %></p>
                </div>
            </div>
        </div>

        <div class="glass-card rounded-2xl p-6">
            <h3 class="text-xl font-semibold text-white mb-6">Recent Campaigns</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-white/10 text-slate-400 text-sm">
                            <th class="py-3 px-4 font-medium">Title</th>
                            <th class="py-3 px-4 font-medium">Slug</th>
                            <th class="py-3 px-4 font-medium">Target</th>
                            <th class="py-3 px-4 font-medium">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recentLinks.length === 0) { %>
                            <tr><td colspan="4" class="text-center py-6 text-slate-500">Belum ada link.</td></tr>
                        <% } else { %>
                            <% recentLinks.forEach(link => { %>
                            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                                <td class="py-4 px-4 font-medium text-white"><%= link.title %></td>
                                <td class="py-4 px-4">
                                    <span class="bg-white/10 text-slate-300 px-2 py-1 rounded text-xs font-mono">/<%= link.slug %></span>
                                </td>
                                <td class="py-4 px-4 text-slate-400 text-sm truncate max-w-[200px]"><%= link.primary_target_url %></td>
                                <td class="py-4 px-4">
                                    <% if(link.is_active) { %>
                                        <span class="px-2 py-1 rounded text-xs font-medium bg-emerald-500/20 text-emerald-400">Active</span>
                                    <% } else { %>
                                        <span class="px-2 py-1 rounded text-xs font-medium bg-rose-500/20 text-rose-400">Inactive</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
` }) %>
